# Resend API Key
RESEND_API_KEY=your_resend_api_key_here

# Firebase Admin Credentials (for Vercel Serverless Function)
# Obtain these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_CLIENT_EMAIL=your-firebase-client-email@example.iam.gserviceaccount.com
# For Vercel, wrap the private key in quotes and escape newlines with \n:
# "-----BEGIN PRIVATE KEY-----\nMIIEvgIBAD... \n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY="your_firebase_private_key_here"

# Email Configuration
# Note: For free/sandbox Resend accounts, FROM_EMAIL must be onboarding@resend.dev,
# and TO_EMAIL must be the email address you signed up to Resend with.
FROM_EMAIL=onboarding@resend.dev
TO_EMAIL=your-notification-email@example.com

# Client-side Firebase Configuration (used by src/firebase.js)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
